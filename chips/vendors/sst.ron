        (
            name: "SST26VF016B(A)",
            device_id: 0x2641,
            total_size: MiB(2),
            features: (wrsr_wren: true, otp: true, sst26_bpr: true),
            voltage: (min: 2700, max: 3600),
            erase_blocks: [
                (opcode: 0x20, regions: [(size: KiB(4), count: 512)]),
                (opcode: 0xD8, regions: [
                    (size: KiB(8),  count: 4),
                    (size: KiB(32), count: 1),
                    (size: KiB(64), count: 30),
                    (size: KiB(32), count: 1),
                    (size: KiB(8),  count: 4),
                ]),
                (opcode: 0xC7, regions: [(size: MiB(2), count: 1)]),
            ],
            tested: (probe: Ok, read: Ok, erase: Ok, write: Ok),
        ),
        (
            name: "SST26VF032",
            device_id: 0x2602,
            total_size: MiB(4),
            features: (wrsr_wren: true, otp: true, sst26_bpr: true),
            voltage: (min: 2700, max: 3600),
            erase_blocks: [
