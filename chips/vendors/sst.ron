// SST (Silicon Storage Technology) SPI Flash Chips
// Ported from flashprog/flashchips.c
//
// SST25 series write behaviour (from flashprog):
//   - Chips with device_id >= 0x25xx ("B" suffix, RDID-probed):
//       use AAI word program (0xAD) → features: (aai_word: true)
//       WRSR requires EWSR (0x50) prefix for most; SST25VF016B accepts either.
//   - Chips with device_id 0x00xx (REMS-probed, older/non-B variants):
//       use single-byte page program (0x02) — no AAI, no aai_word flag.
//       WRSR requires EWSR (0x50).
//   - SST25VF064C and all SST25WFxxxA/B variants: standard 256-byte page program.
//
// SST26 series:
//   - Standard 256-byte page program (FEATURE_WRSR_WREN).
//   - Block protection uses a per-block register, not SR BP bits.
//     Global unlock: WREN + ULBPR (0x98) — handled by sst26_global_unprotect().
//   - Non-uniform 0xD8 erase: 4×8K boot sectors at each end, 64K blocks in middle.
//
// SST25WF020A / SST25WF040B / SST25WF080B use SANYO_ID (0x62), not SST_ID (0xBF).
// Those chips are in chips/vendors/sanyo.ron instead.

(
    vendor: "SST",
    manufacturer_id: 0xBF,
    chips: [

        // ====================================================================
        // SST25VF series — RDID-probed (device_id 0x25xx)
        // "B" suffix chips: AAI word program (0xAD), WRSR needs EWSR
        // Non-"B" chips below this group: single-byte PP, WRSR needs EWSR
        // ====================================================================

        (
            name: "SST25VF512",
            device_id: 0x2548,
            total_size: KiB(64),
            // Older chip, no AAI (uses 0xAF variant), WRSR needs EWSR
            features: (wrsr_ewsr: true),
            voltage: (min: 2700, max: 3600),
            erase_blocks: [
                (opcode: 0x20, regions: [(size: KiB(4), count: 16)]),
                (opcode: 0x52, regions: [(size: KiB(32), count: 2)]),
                (opcode: 0x60, regions: [(size: KiB(64), count: 1)]),
            ],
        ),
        (
            name: "SST25VF512A",
            device_id: 0x4800,
            total_size: KiB(64),
            features: (wrsr_wren: true),
            voltage: (min: 2700, max: 3600),
            erase_blocks: [
                (opcode: 0x20, regions: [(size: KiB(4), count: 16)]),
                (opcode: 0x52, regions: [(size: KiB(32), count: 2)]),
                (opcode: 0x60, regions: [(size: KiB(64), count: 1)]),
            ],
        ),
        (
            name: "SST25VF010",
            device_id: 0x2549,
            total_size: KiB(128),
            // Older chip, no AAI (uses 0xAF variant), WRSR needs EWSR
            features: (wrsr_ewsr: true),
            voltage: (min: 2700, max: 3600),
            erase_blocks: [
                (opcode: 0x20, regions: [(size: KiB(4), count: 32)]),
                (opcode: 0x52, regions: [(size: KiB(32), count: 4)]),
                (opcode: 0x60, regions: [(size: KiB(128), count: 1)]),
            ],
        ),
        (
            name: "SST25VF010A",
            device_id: 0x4900,
            total_size: KiB(128),
            features: (wrsr_wren: true),
            voltage: (min: 2700, max: 3600),
            erase_blocks: [
                (opcode: 0x20, regions: [(size: KiB(4), count: 32)]),
                (opcode: 0x52, regions: [(size: KiB(32), count: 4)]),
                (opcode: 0x60, regions: [(size: KiB(128), count: 1)]),
            ],
        ),
        (
            name: "SST25VF020",
            device_id: 0x2543,
            total_size: KiB(256),
            // Older chip, no AAI (uses 0xAF variant), WRSR needs EWSR
            features: (wrsr_ewsr: true),
            voltage: (min: 2700, max: 3600),
            erase_blocks: [
                (opcode: 0x20, regions: [(size: KiB(4), count: 64)]),
                (opcode: 0x52, regions: [(size: KiB(32), count: 8)]),
                (opcode: 0x60, regions: [(size: KiB(256), count: 1)]),
            ],
