        // ====================================================================
        // SST26 series — 256-byte page program, WRSR uses WREN
        // Block protection: per-block register, unlock with WREN + ULBPR (0x98)
        // Erase: uniform 4KB (0x20), non-uniform 64KB (0xD8), chip (0xC7)
        //
        // The 0xD8 layout is asymmetric:
        //   SST26VF016B(A): 4×8K + 1×32K + 30×64K + 1×32K + 4×8K
        //   SST26VF032:     4×8K + 1×32K + 62×64K + 1×32K + 4×8K
        //   SST26VF032B(A): same as SST26VF032
        //   SST26VF064B(A): 4×8K + 1×32K + 126×64K + 1×32K + 4×8K
        //   SST26VF080A:    uniform 4K/32K/64K (no asymmetric boot sectors)
        // ====================================================================

        (
            name: "SST26VF016",
            device_id: 0x2601,
            total_size: MiB(2),
            features: (wrsr_wren: true, otp: true, sst26_bpr: true),
            voltage: (min: 2700, max: 3600),
            erase_blocks: [
                (opcode: 0x20, regions: [(size: KiB(4), count: 512)]),
                (opcode: 0xD8, regions: [
                    (size: KiB(8),  count: 4),
                    (size: KiB(32), count: 1),
                    (size: KiB(64), count: 30),
                    (size: KiB(32), count: 1),
                    (size: KiB(8),  count: 4),
                ]),
                (opcode: 0xC7, regions: [(size: MiB(2), count: 1)]),
            ],
