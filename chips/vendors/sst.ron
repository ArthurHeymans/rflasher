            device_id: 0x008D,
            total_size: KiB(512),
            features: (wrsr_ewsr: true, aai_word: true),
            write_granularity: Byte,
            voltage: (min: 2700, max: 3600),
            erase_blocks: [
                (opcode: 0x20, regions: [(size: KiB(4), count: 128)]),
                (opcode: 0x52, regions: [(size: KiB(32), count: 16)]),
                (opcode: 0xD8, regions: [(size: KiB(64), count: 8)]),
                (opcode: 0x60, regions: [(size: KiB(512), count: 1)]),
                (opcode: 0xC7, regions: [(size: KiB(512), count: 1)]),
            ],
            tested: (probe: Ok, read: Ok, erase: Ok, write: Ok),
        ),
        (
            name: "SST25VF512(A)",
            device_id: 0x0048,
            total_size: KiB(64),
            features: (wrsr_ewsr: true),
            voltage: (min: 2700, max: 3600),
            erase_blocks: [
                (opcode: 0x20, regions: [(size: KiB(4), count: 16)]),
                (opcode: 0x52, regions: [(size: KiB(32), count: 2)]),
                (opcode: 0xD8, regions: [(size: KiB(32), count: 2)]),
                (opcode: 0x60, regions: [(size: KiB(64), count: 1)]),
                (opcode: 0xC7, regions: [(size: KiB(64), count: 1)]),
            ],
            tested: (probe: Ok, read: Ok, erase: Ok, write: Ok),
        ),

        // ====================================================================
        // SST25WF series — 1.8V, AAI word program (0xAD)
        // Note: SST25WF020A, SST25WF040B, SST25WF080B use SANYO_ID (0x62) —
        // those are in chips/vendors/sanyo.ron.
        // ====================================================================

        (
            name: "SST25WF512",
            device_id: 0x2501,
            total_size: KiB(64),
